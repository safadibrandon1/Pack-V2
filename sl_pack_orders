// ─── Item key: itemId used as the pallet-assignment key ───────────────────────
function ikey(item) {
    return item.itemId;
}

// ─── Item Progress Panel ──────────────────────────────────────────────────────
function renderItemProgress() {
    const list = document.getElementById('item-progress-list');
    if (!list) return;

    const assigned = computeItemAssignments();

    list.innerHTML = S.aggItems.map((item) => {
        const k        = ikey(item);
        const total    = item.totalQty;
        const done     = assigned[k] || 0;
        const remain   = total - done;
        const pct      = Math.min(100, total > 0 ? Math.round(done / total * 100) : 0);
        const over     = done > total;
        const complete = done === total && !over;

        const barClass = over ? 'over' : (complete ? 'complete' : '');
        const remClass = complete ? 'ok' : (over ? 'bad' : '');
        const remText  = complete
            ? '\u2713 All assigned'
            : (over ? '\u26a0 Over by ' + (done - total) : remain + ' remaining');

        return '<div class="item-row">' +
            '<div class="item-row-top">' +
              '<span class="item-name">' + esc(item.itemName || item.itemId) + '</span>' +
              '<span class="item-qty-info">' + done + ' / ' + total + '</span>' +
            '</div>' +
            '<div class="item-bar-wrap">' +
              '<div class="item-bar ' + barClass + '" style="width:' + pct + '%"></div>' +
            '</div>' +
            '<div class="item-remaining ' + remClass + '">' + remText + '</div>' +
        '</div>';
    }).join('');
}

// ─── Compute total qty assigned to each item across all pallets ───────────────
function computeItemAssignments() {
    const totals = {};
    S.pallets.forEach(({ pid }) => {
        const piMap = S.palletItems[pid] || {};
        Object.entries(piMap).forEach(([k, qty]) => {
            totals[k] = (totals[k] || 0) + (parseFloat(qty) || 0);
        });
    });
    return totals;
}

// ─── Validate: all items assigned, no empty pallets, dims/weight required ─────
function validateAndToggleSubmit() {
    const assigned = computeItemAssignments();
    const allItemsDone = S.aggItems.every(item => (assigned[ikey(item)] || 0) === item.totalQty);

    const missingPkgType = S.pallets.filter(p => !p.pkgTypeId);

    const emptyPallets = S.pallets.filter(p => {
        const piMap = S.palletItems[p.pid] || {};
        return !Object.values(piMap).some(qty => (parseFloat(qty) || 0) > 0);
    });

    const missingDimPallets = S.pallets.filter(p =>
        !(parseFloat(p.length) > 0) || !(parseFloat(p.width) > 0) ||
        !(parseFloat(p.height) > 0) || !(parseFloat(p.weight) > 0)
    );

    const btn = document.getElementById('btn-submit-pack');
    const msg = document.getElementById('builder-msg');

    const valid = S.pallets.length > 0 && allItemsDone &&
                  missingPkgType.length === 0 && emptyPallets.length === 0 && missingDimPallets.length === 0;
    btn.disabled = !valid;

    if (!S.pallets.length) {
        msg.textContent = 'Add at least one package.';
    } else if (missingPkgType.length > 0) {
        const n = missingPkgType.length;
        msg.textContent = n + ' package' + (n === 1 ? ' is' : 's are') + ' missing a Package Type.';
    } else if (emptyPallets.length > 0) {
        const n = emptyPallets.length;
        msg.textContent = n + ' package' + (n === 1 ? ' has' : 's have') + ' no items assigned.';
    } else if (missingDimPallets.length > 0) {
        msg.textContent = 'All packages require Length, Width, Height, and Weight.';
    } else if (!allItemsDone) {
        const n = S.aggItems.filter(item => (assigned[ikey(item)] || 0) !== item.totalQty).length;
        msg.textContent = n + ' item' + (n === 1 ? '' : 's') +
            ' not fully assigned. Assign 100% of quantities to enable submit.';
    } else {
        msg.textContent = '';
    }
}

// ─── Add a new pallet ─────────────────────────────────────────────────────────
function addPallet() {
    const pid  = S.nextPid++;
    const dd   = S.dropdowns || {};

    // Inherit the last pallet's package type; blank on first pallet
    const prev       = S.pallets.length > 0 ? S.pallets[S.pallets.length - 1] : null;
    const prevPkgId  = prev ? prev.pkgTypeId : '';
    const prevPt     = prevPkgId ? (dd.packageTypes || []).find(x => x.key === prevPkgId) : null;

    S.pallets.push({
        pid,
        pkgTypeId: prevPkgId,
        length:    prevPt ? (prevPt.length || '') : '',
        width:     prevPt ? (prevPt.width  || '') : '',
        height:    prevPt ? (prevPt.height || '') : '',
        weight:    '',
        wuId:      dd.defaultWuKey || '',
        duId:      dd.defaultDuKey || '',
    });

    S.palletItems[pid] = {};

    renderPalletList();
    validateAndToggleSubmit();

    setTimeout(() => {
        const list = document.getElementById('pallet-list');
        if (list) list.scrollTop = list.scrollHeight;
    }, 50);
}

// ─── Render all pallet cards ──────────────────────────────────────────────────
function renderPalletList() {
    const list = document.getElementById('pallet-list');
    if (!list) return;
    list.innerHTML = '';
    S.pallets.forEach(p => {
        const card = document.createElement('div');
        card.className   = 'pallet-card';
        card.dataset.pid = p.pid;
        card.innerHTML   = buildPalletCardHTML(p);
        list.appendChild(card);
    });
}

function buildPalletCardHTML(p) {
    const dd  = S.dropdowns || {};
    const idx = S.pallets.findIndex(x => x.pid === p.pid);

    const pkgOpts = '<option value="">— Select type —</option>' +
        (dd.packageTypes || []).map(pt =>
            '<option value="' + esc(pt.key) + '"' + (pt.key === p.pkgTypeId ? ' selected' : '') + '>' +
            esc(pt.label) + '</option>'
        ).join('');

    const wuOpts = (dd.weightUnits || []).map(u =>
        '<option value="' + esc(u.key) + '"' + (u.key === p.wuId ? ' selected' : '') + '>' +
        esc(u.label) + '</option>'
    ).join('');

    const duOpts = (dd.dimUnits || []).map(u =>
        '<option value="' + esc(u.key) + '"' + (u.key === p.duId ? ' selected' : '') + '>' +
        esc(u.label) + '</option>'
    ).join('');

    const piMap    = S.palletItems[p.pid] || {};
    const assigned = computeItemAssignments();

    const itemRows = S.aggItems.map((item) => {
        const k     = ikey(item);
        const qty   = piMap[k] != null ? piMap[k] : '';
        const total = item.totalQty;
        const done  = assigned[k] || 0;
        const myQty = parseFloat(qty) || 0;
        const avail = Math.max(0, total - (done - myQty));
        const over  = myQty > avail;

        return '<div class="pallet-item-row">' +
            '<span class="pallet-item-name">' + esc(item.itemName || item.itemId) + '</span>' +
            '<button class="btn btn-secondary btn-sm" ' +
                    'data-pid="' + p.pid + '" data-ikey="' + esc(k) + '" ' +
                    'onclick="addItemToPallet(this.dataset.pid,this.dataset.ikey)" ' +
                    'title="Fill remaining quantity">All</button>' +
            '<span class="pallet-item-max">max&nbsp;' + avail + '</span>' +
            '<input type="number" min="0" max="' + total + '" step="1" ' +
                   'class="pallet-item-qty' + (over ? ' over' : '') + '" ' +
                   'value="' + esc(String(qty)) + '" ' +
                   'data-pid="' + p.pid + '" data-ikey="' + esc(k) + '" ' +
                   'oninput="onQtyChange(' + p.pid + ',this.dataset.ikey)" ' +
                   'onchange="onQtyChange(' + p.pid + ',this.dataset.ikey)">' +
        '</div>';
    }).join('');

    const duLabel = getDuLabel(p.duId);

    return '<div class="pallet-card-hdr">' +
        '<span class="pallet-num">Package ' + (idx + 1) + '</span>' +
        (S.pallets.length > 1
            ? '<button class="btn btn-danger btn-sm" onclick="removePallet(' + p.pid + ')">Remove</button>'
            : '') +
    '</div>' +
    '<div class="pallet-body">' +
        '<div class="pallet-dims">' +
            '<div class="pallet-field"><label>Package Type&thinsp;<span class="req-star">*</span></label>' +
                '<select class="wide' + (!p.pkgTypeId ? ' req-missing' : '') + '" onchange="onPkgTypeChange(' + p.pid + ',this.value)">' +
                pkgOpts + '</select></div>' +
            '<div class="pallet-field"><label>L&thinsp;<span class="req-star">*</span></label>' +
                '<input type="number" min="0" step="0.01" value="' + esc(p.length) + '" ' +
                       'class="' + (!(parseFloat(p.length) > 0) ? 'req-missing' : '') + '" ' +
                       'data-field="length" oninput="onDimChange(' + p.pid + ',this.dataset.field,this.value)"></div>' +
            '<div class="pallet-field"><label>W&thinsp;<span class="req-star">*</span></label>' +
                '<input type="number" min="0" step="0.01" value="' + esc(p.width) + '" ' +
                       'class="' + (!(parseFloat(p.width) > 0) ? 'req-missing' : '') + '" ' +
                       'data-field="width" oninput="onDimChange(' + p.pid + ',this.dataset.field,this.value)"></div>' +
            '<div class="pallet-field"><label>H&thinsp;<span class="req-star">*</span></label>' +
                '<input type="number" min="0" step="0.01" value="' + esc(p.height) + '" ' +
                       'class="' + (!(parseFloat(p.height) > 0) ? 'req-missing' : '') + '" ' +
                       'data-field="height" oninput="onDimChange(' + p.pid + ',this.dataset.field,this.value)"></div>' +
            '<div class="pallet-field"><label>Dim&nbsp;Unit</label>' +
                '<select onchange="onDimUnitChange(' + p.pid + ',this.value)">' +
                duOpts + '</select></div>' +
            '<div class="pallet-field"><label>Weight&thinsp;<span class="req-star">*</span></label>' +
                '<input type="number" min="0" step="0.01" value="' + esc(p.weight) + '" ' +
                       'class="' + (!(parseFloat(p.weight) > 0) ? 'req-missing' : '') + '" ' +
                       'data-field="weight" oninput="onDimChange(' + p.pid + ',this.dataset.field,this.value)"></div>' +
            '<div class="pallet-field"><label>Wt&nbsp;Unit</label>' +
                '<select onchange="onWtUnitChange(' + p.pid + ',this.value)">' +
                wuOpts + '</select></div>' +
        '</div>' +
        '<div class="pallet-items-hdr" style="margin-top:8px">Item Quantities</div>' +
        itemRows +
    '</div>';
}

// ─── Pallet field change handlers ─────────────────────────────────────────────
function addItemToPallet(pid, k) {
    const assigned = computeItemAssignments();
    const piMap    = S.palletItems[pid] || {};
    const item     = S.aggItems.find(it => ikey(it) === k);
    if (!item) return;
    const myQty    = parseFloat(piMap[k]) || 0;
    piMap[k]       = Math.max(0, item.totalQty - ((assigned[k] || 0) - myQty));
    S.palletItems[pid] = piMap;
    renderPalletList();
    renderItemProgress();
    validateAndToggleSubmit();
}

function removePallet(pid) {
    S.pallets    = S.pallets.filter(p => p.pid !== pid);
    delete S.palletItems[pid];
    renderPalletList();
    renderItemProgress();
    validateAndToggleSubmit();
}

function onPkgTypeChange(pid, pkgTypeId) {
    const p = S.pallets.find(x => x.pid === pid);
    if (!p) return;
    p.pkgTypeId = pkgTypeId;
    const pt = (S.dropdowns.packageTypes || []).find(x => x.key === pkgTypeId);
    if (pt) { p.length = pt.length || ''; p.width = pt.width || ''; p.height = pt.height || ''; }
    const card = document.querySelector('.pallet-card[data-pid="' + pid + '"]');
    if (card) card.innerHTML = buildPalletCardHTML(p);
    validateAndToggleSubmit();
}

function onDimChange(pid, field, value) {
    const p = S.pallets.find(x => x.pid === pid);
    if (!p) return;
    p[field] = value;
    // Update red-border indicator on this input in real time
    const card = document.querySelector('.pallet-card[data-pid="' + pid + '"]');
    if (card) {
        const inp = card.querySelector('input[data-field="' + field + '"]');
        if (inp) inp.classList.toggle('req-missing', !(parseFloat(value) > 0));
    }
    validateAndToggleSubmit();
}

function onDimUnitChange(pid, duId) {
    const p = S.pallets.find(x => x.pid === pid);
    if (!p) return;
    p.duId = duId;
    const card = document.querySelector('.pallet-card[data-pid="' + pid + '"]');
    if (card) card.innerHTML = buildPalletCardHTML(p);
}

function onWtUnitChange(pid, wuId) {
    const p = S.pallets.find(x => x.pid === pid);
    if (p) p.wuId = wuId;
}

function onQtyChange(pid, k) {
    const input = document.querySelector(
        'input.pallet-item-qty[data-pid="' + pid + '"][data-ikey="' + CSS.escape(k) + '"]'
    );
    if (!input) return;

    const val = parseFloat(input.value) || 0;
    if (!S.palletItems[pid]) S.palletItems[pid] = {};
    S.palletItems[pid][k] = val;

    renderItemProgress();
    validateAndToggleSubmit();

    // Refresh "max" hints for all inputs sharing this ikey
    const assigned = computeItemAssignments();
    document.querySelectorAll('input.pallet-item-qty[data-ikey="' + CSS.escape(k) + '"]').forEach((inp) => {
        const rowPid = parseInt(inp.dataset.pid, 10);
        const item   = S.aggItems.find(it => ikey(it) === k);
        if (!item) return;
        const myQty  = parseFloat(inp.value) || 0;
        const total  = item.totalQty;
        const done   = assigned[k] || 0;
        const avail  = Math.max(0, total - (done - myQty));
        const maxEl  = inp.closest('.pallet-item-row') && inp.closest('.pallet-item-row').querySelector('.pallet-item-max');
        if (maxEl) maxEl.textContent = 'max\u00a0' + avail;
        inp.classList.toggle('over', myQty > avail);
    });
}

// ─── Helper: dim unit label ────────────────────────────────────────────────────
function getDuLabel(duId) {
    const dd = S.dropdowns;
    if (!dd) return '';
    const u = (dd.dimUnits || []).find(x => x.key === duId);
    return u ? u.label : '';
}

// ─── Submit Packing ───────────────────────────────────────────────────────────
document.getElementById('btn-submit-pack').addEventListener('click', submitPacking);

async function submitPacking() {
    const btn = document.getElementById('btn-submit-pack');
    const msg = document.getElementById('builder-msg');

    // Final validation (mirrors validateAndToggleSubmit)
    const assigned        = computeItemAssignments();
    const allDone         = S.aggItems.every(item => (assigned[ikey(item)] || 0) === item.totalQty);
    const hasEmptyPallet  = S.pallets.some(p => !Object.values(S.palletItems[p.pid] || {}).some(q => (parseFloat(q) || 0) > 0));
    const hasMissingDims  = S.pallets.some(p => !(parseFloat(p.length) > 0) || !(parseFloat(p.width) > 0) || !(parseFloat(p.height) > 0) || !(parseFloat(p.weight) > 0));
    if (!allDone || !S.pallets.length || hasEmptyPallet || hasMissingDims) return;

    btn.disabled    = true;
    btn.textContent = 'Submitting\u2026';
    msg.textContent = '';

    // Build fulfillments list
    const fulfillments = [];
    S.orders
        .filter(o => S.selectedToIds.has(o.toId))
        .forEach((o) => {
            o.fulfillments.forEach((f) => {
                fulfillments.push({ ifId: f.ifId, ifTranId: f.ifTranId, toId: o.toId, toTranId: o.toTranId, sourceId: o.sourceId, destId: o.destId });
            });
        });

    // Pre-compute item→IF-line distribution across all pallets.
    // Line state (lineIdx, lineConsumed) carries forward across pallets so each
    // original IF line's quantity is consumed exactly once in order, regardless
    // of how the user has split quantities across packages.
    const lineState = {};  // { [itemId]: { lineIdx, lineConsumed } }
    S.aggItems.forEach((agg) => {
        lineState[agg.itemId] = { lineIdx: 0, lineConsumed: 0 };
    });

    const distributedItemsByPallet = S.pallets.map((p) => {
        const piMap = S.palletItems[p.pid] || {};
        const items = [];
        S.aggItems.forEach((agg) => {
            const assignedQty = parseFloat(piMap[agg.itemId]) || 0;
            if (!assignedQty) return;
            let palletRemaining = assignedQty;
            const st = lineState[agg.itemId];
            while (palletRemaining > 0 && st.lineIdx < agg.lines.length) {
                const line        = agg.lines[st.lineIdx];
                const lineAvail   = line.quantity - st.lineConsumed;
                const take        = Math.min(palletRemaining, lineAvail);
                if (take > 0) {
                    items.push({ itemId: agg.itemId, quantity: take, ifId: line.ifId, lineNum: line.lineNum });
                    palletRemaining   -= take;
                    st.lineConsumed   += take;
                }
                if (st.lineConsumed >= line.quantity) { st.lineIdx++; st.lineConsumed = 0; }
            }
        });
        return items;
    });

    // Build pallets payload — read current input values from DOM
    const palletsPayload = S.pallets.map((p, pi) => {
        const card   = document.querySelector('.pallet-card[data-pid="' + p.pid + '"]');

        // Read dim/weight inputs from card to capture any unsaved keystrokes
        const getVal = (sel) => {
            if (!card) return '';
            const el = card.querySelector(sel);
            return el ? el.value : '';
        };

        return {
            pkgTypeId: p.pkgTypeId,
            length:    getVal('input[data-field="length"]') || p.length,
            width:     getVal('input[data-field="width"]')  || p.width,
            height:    getVal('input[data-field="height"]') || p.height,
            weight:    getVal('input[data-field="weight"]') || p.weight,
            wuId:      p.wuId,
            duId:      p.duId,
            items:     distributedItemsByPallet[pi],
        };
    });

    const notes = (document.getElementById('pack-notes') || {}).value || '';

    try {
        const data = await apiPost({
            action:       'submitPacking',
            fulfillments,
            pallets:      palletsPayload,
            notes,
        });

        if (!data.success) throw new Error(data.error);

        // Replace builder body with success message
        const wrap = document.getElementById('builder-loading-wrap');
        wrap.style.overflow = '';
        wrap.innerHTML =
            '<div class="alert alert-ok" style="margin:16px">' +
            '\u2713 Packing complete! Created <strong>' + data.shipUnitCount + '</strong> pallet' +
            (data.shipUnitCount === 1 ? '' : 's') + ' and <strong>' + data.shipUnitItemCount +
            '</strong> item assignment' + (data.shipUnitItemCount === 1 ? '' : 's') + '.' +
            '<br><br>Shipment Summary ID: <strong>' + esc(data.summaryId) + '</strong>' +
            '</div>';

        const closeBtn = document.getElementById('btn-close-window');
        closeBtn.style.display = 'inline-block'; // Show dedicated Close button

        // Notify the opener (Item Fulfillment page) to reload
        window.opener && window.opener.postMessage({ type: 'PACKING_COMPLETE' }, '*');

        //Hide the Submit Button
        const submitBtn = document.getElementById('btn-submit-pack');
        if (submitBtn) submitBtn.style.display = 'none';

        // Update footer — Done closes the window
        btn.class       = "btn btn-secondary btn-sm";
        btn.textContent = 'Done';
        btn.disabled    = true;
        btn.type        = 'button';
        btn.onclick     = () => window.close();
        msg.textContent = '';

        // Offer to close the popup after a short delay
        setTimeout(() => {
            const wrap2 = document.getElementById('builder-loading-wrap');
            if (wrap2) {
                wrap2.innerHTML +=
                    '<div style="margin:0 16px">' +
                    '<button class="btn btn-secondary btn-sm" onclick="window.close()">Close Window</button>' +
                    '</div>';
            }
        }, 600);

    } catch (e) {
        msg.textContent = 'Submit error: ' + e.message;
        btn.disabled    = false;
        btn.textContent = 'Submit Packing';
    }
}
</script>
</body>
</html>`;

    return { onRequest };
});
